# Database (REQUIRED - set your own credentials)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/norwich_events

# Claude AI
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Site
SITE_URL=https://norwicheventshub.com

# Admin (REQUIRED - set a strong password)
ADMIN_PASSWORD=

# Google Sheets (optional - for syncing to existing sheet)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Scraping
SCRAPE_DAYS_AHEAD=90
MIN_QUALITY_SCORE=50
AUTO_APPROVE_THRESHOLD=80

# Paths
EVIDENCE_DIR=evidence
EXPORTS_DIR=exports

# Rate limiting (seconds between requests per domain)
REQUEST_DELAY=2
